sequenceDiagram
    autonumber

    participant UI as UI (Dice Button)
    participant GM as GameManager
    participant TFC as TurnFlowCoordinator
    participant Dice as DiceManager
    participant Move as StandardMovementStrategy
    participant Board as BoardManager
    participant TCM as TurnCycleManager

    %% turn_start
    GM->>TFC: TurnStartedEvent
    GM->>GM: turnPhase = StartTurn→PreRoll
    TFC->>TFC: phase = AwaitingRoll

    %% roll_request
    UI->>GM: rollDiceRequested(true)
    GM->>Dice: RollDice()
    Dice->>GM: DiceRolledEvent
    Dice->>TFC: DiceRolledEvent
    Dice->>Move: DiceRolledEvent

    GM->>GM: turnPhase = RollingDice→MovingPiece
    TFC->>TFC: phase = AwaitingMovement
    Move->>Board: MovePlayer(path)

    %% movement_completed
    Board->>GM: pieceMoveCompleted(true)
    Board->>TFC: pieceMoveCompleted(true)

    TFC->>TFC: phase = AwaitingResolution
    TFC->>TFC: ActionResolvedEvent
    Move->>Board: landed.OnLanded()
    Move->>GM: spaceResolutionCompleted(true)
    GM->>GM: turnPhase = ResolvingSpace→PostTurn

    %% advance_turn
    TFC->>TCM: Advance()
    TCM-->>TFC: nextPlayer
    TFC->>GM: TurnStartedEvent(nextPlayer)
