sequenceDiagram
    autonumber
    participant PS as PropertySpace / TileAdapter
    participant RM as RentManager
    participant OS as OwnershipServiceAdapter
    participant STR as StandardRentStrategy
    participant RS as RuleSet
    participant EA as EconomyAdapter
    participant TEN as Player
    
    Note over PS,TEN: Player finishes movement and lands on a rentable tile

    PS->>RM: TryChargeRent(TEN, tileAdapter, diceTotal)

    %% Ensure RentManager has its deps (Awake/EnsureDependencies)
    RM->>RM: EnsureDependencies()

    %% Look up owner
    RM->>OS: GetOwner(tileAdapter)
    OS-->>RM: OWN

    alt No owner or OWN == TEN
        RM-->>PS: return (no rent charged)
    else Has different owner
        %% Compute rent using strategy & rules
        RM->>STR: ComputeRent(tileAdapter, OWN, diceTotal, OS, RS)

        alt tileAdapter.IsMortgaged == true
            STR-->>RM: 0
        else tileAdapter.Type == Street
            STR->>OS: CountOwnedInGroup(OWN, tileAdapter.Group)
            OS-->>STR: ownedInGroup
            STR->>RS: StreetsInGroup(tileAdapter.Group)
            RS-->>STR: streetsInSet

            alt tileAdapter.HouseCount > 0
                STR-->>STR: rent = tileAdapter.RentByHouses[HouseCount]
            else No houses
                alt ownedInGroup == streetsInSet (monopoly)
                    STR-->>STR: rent = tileAdapter.BaseRent * 2
                else Not a monopoly
                    STR-->>STR: rent = tileAdapter.BaseRent
                end
            end

            STR-->>RM: rent
        else tileAdapter.Type == Railroad
            STR->>OS: CountRailroadsOwned(OWN)
            OS-->>STR: rrCount
            STR->>RS: RailroadBaseRent()
            RS-->>STR: baseRR
            STR-->>RM: rent = baseRR * (2 ^ (rrCount - 1))
        else tileAdapter.Type == Utility
            STR->>OS: OwnsBothUtilities(OWN)
            OS-->>STR: ownsBoth
            alt ownsBoth == true
                STR->>RS: UtilityRentBothMult()
                RS-->>STR: mult
            else
                STR->>RS: UtilityRentSingleMult()
                RS-->>STR: mult
            end
            STR-->>RM: rent = diceTotal * mult
        else Other tile type
            STR-->>RM: 0
        end

        %% Transfer money if rent > 0
        RM->>RM: if (rent <= 0) return
        RM->>EA: Transfer(TEN, OWN, rent)
        EA-->>RM: true / false (transfer success)

        RM-->>PS: Rent charge complete 
    end
