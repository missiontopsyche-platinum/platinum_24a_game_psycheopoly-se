%% Turn Advance Sequence Daigram
%% Last Updated: 3/18/2026
%% Version: 1.0

%% Purpose
%% To show the basic steps for the game to advance to the next player

%% Scope
%% The turn logic and player elimination logic

sequenceDiagram
    actor Player
    participant UI as TurnUI
    participant GM as GameManager
    participant TOM as TurnOrderManager
    participant PTS as PlayerTurnState
    participant PM as PlayerManager

    Player->>UI: End Turn
    UI->>GM: OnEndTurn()

    GM->>TOM: AdvanceTurn()

    TOM->>PTS: ConsumeSkip(current)

    TOM->>PTS: GetExtraTurn(current)
    PTS-->>TOM: extraTurn

    alt extra turn
        TOM-->>GM: Same player continues
        GM->>UI: UpdateUI(current)
    else
        TOM->>PTS: IsEliminated(next)
        PTS-->>TOM: bool

        loop skip eliminated players
            TOM->>PTS: IsSkippedThisRound(candidate)
            PTS-->>TOM: skip
        end

        TOM-->>GM: nextPlayerIndex
        GM->>PM: SetActivePlayer(next)
        GM->>UI: UpdateUI(next)
    end
