%% TurnPhaseFSMDiagram
%% Last Updated: 3/18/2026
%% Version: 1.0

%% Purpose
%% To show the different turn phases of the state machine within the game

%% Scope
%% The turn phase finite state machine

stateDiagram-v2
    %% Turn Phase Finite State Machine

    [*] --> PreRoll

    state "PreRoll" as PreRoll
    PreRoll --> RollingDice: RollDiceRequested\n(from DiceRoll button)

    state "RollingDice" as RollingDice
    RollingDice --> MovingPiece: DiceRolled\n(die1, die2, total)

    state "MovingPiece" as MovingPiece
    MovingPiece --> MovingPiece: PieceMoveCompleted == false\n(animation not done)
    MovingPiece --> ResolvingSpace: PieceMoveCompleted == true

    state "ResolvingSpace" as ResolvingSpace
    ResolvingSpace --> ResolvingCards: CardDrawn\n(from CardDeck)
    ResolvingSpace --> PostTurn: No card drawn /\nspace fully resolved

    state "ResolvingCards" as ResolvingCards
    ResolvingCards --> PostTurn: All card effects\nresolved

    state "PostTurn" as PostTurn
    PostTurn --> EndTurn: TurnEndedEvent(true)\n(End Turn button clicked)
    PostTurn --> PostTurn: TurnEndedEvent(false)\n(cancel / ignore)

    state "EndTurn" as EndTurn
    EndTurn --> NextTurn: AdvanceTurn\n(increment player/turn)

    state "NextTurn" as NextTurn
    NextTurn --> PreRoll: StartTurn(nextPlayer)

    NextTurn --> [*]: GameOver\n(if GameState moves to GameOver)
