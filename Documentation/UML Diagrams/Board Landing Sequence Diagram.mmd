sequenceDiagram
    autonumber
    actor Player
    participant GameManager
    participant BoardManager
    participant Space as LandedSpace
    participant Bank
    participant Owner
    participant RentManager
    participant PurchaseManager
    participant CardDeck
    participant JailManager

    Player->>GameManager: FinishMove(diceTotal)
    GameManager->>BoardManager: GetSpaceForPlayer(Player)
    BoardManager-->>GameManager: LandedSpace

    GameManager->>LandedSpace: OnLanded(Player)

    alt Landed on GO
        note over LandedSpace,Bank: Player collects $200
        Player->>Bank: Receive $200
    else Unowned Property
        note over LandedSpace,PurchaseManager: Offer player the option to buy
        PurchaseManager-->>Player: Prompt to buy property
        alt Player buys
            Player->>Bank: Pay purchase price
            Bank-->>Owner: Assign property to Player
        else Player declines
            note over GameManager: Start auction (optional)
        end
    else Owned Property
        note over LandedSpace,RentManager: Calculate rent based on rules
        LandedSpace-->>Owner: Identify owner
        LandedSpace-->>RentManager: Compute rent
        RentManager-->>GameManager: Return rent amount
        alt Player can pay
            Player->>Bank: Pay rent
            Bank-->>Owner: Transfer rent
        else Player cannot pay
            note over GameManager: Handle mortgages or bankruptcy
        end
    else Chance or Community Chest
        LandedSpace-->>CardDeck: Draw card
        CardDeck-->>GameManager: Card effect
        GameManager->>Player: Apply card effect
        alt Card moves Player
            GameManager->>BoardManager: Move player to new space
            BoardManager-->>GameManager: New LandedSpace
            GameManager->>NewLandedSpace: Resolve new landing
        else Card adjusts money
            note over GameManager,Player: Modify player funds
        end
    else Tax Space
        note over LandedSpace,Bank: Player pays tax
        Player->>Bank: Pay tax
    else Free Parking
        note over LandedSpace: No action (default rules)
    else Go To Jail
        note over LandedSpace,JailManager: Send Player to Jail
        GameManager->>JailManager: Move Player to Jail
    else Jail (Just Visiting)
        note over LandedSpace: No effect
    end

    GameManager-->>Player: End landing resolution
