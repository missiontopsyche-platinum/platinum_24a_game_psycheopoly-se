sequenceDiagram
    actor Player
    participant BoardManager
    participant CardSpace
    participant CardDeck
    participant Card
    participant CardEffect
    participant CardPopupUI

    Player->>BoardManager: MoveTo(spaceIndex)
    BoardManager->>CardSpace: ResolveLanding(player)

    CardSpace->>CardDeck: DrawCard(player)
    CardDeck-->>CardSpace: card

    CardSpace->>CardPopupUI: ShowCard(card)
    Player->>CardPopupUI: Click OK

    CardPopupUI->>CardSpace: Confirm(card)
    CardSpace->>Card: Resolve(player)
    Card->>CardEffect: ApplyEffect(player)

    CardDeck->>CardDeck: Enqueue card back
