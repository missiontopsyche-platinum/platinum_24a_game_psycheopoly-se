using NUnit.Framework;
using UnityEngine;
using UnityEngine.UI;
using System.Reflection;

namespace Tests.EditMode.UITests
{
    public class DiceFaceViewTests
    {
        //helpers
        private static Sprite MakeFace(Color c)
        {
            var tex = new Texture2D(8, 8, TextureFormat.RGBA32, false);
            var px = tex.GetPixels32();
            for (int i = 0; i < px.Length; i++) px[i] = c;
            tex.SetPixels32(px);
            tex.Apply();
            return Sprite.Create(tex, new Rect(0, 0, 8, 8), new Vector2(0.5f, 0.5f), 100f);
        }

        private static Sprite[] MakeSixFaces()
        {
            return new[]
            {
                MakeFace(Color.red),
                MakeFace(Color.green),
                MakeFace(Color.blue),
                MakeFace(Color.yellow),
                MakeFace(new Color(1f,0f,1f)), 
                MakeFace(Color.cyan)
            };
        }

        private static void SetPrivateField(object target, string name, object value)
        {
            var f = target.GetType().GetField(name, BindingFlags.Instance | BindingFlags.NonPublic);
            f.SetValue(target, value);
        }
        // -------------------------------------

        [Test]
        public void DiceFaceView_SetValue_WithinRange_UsesCorrectSprite()
        {
            //arrange
            var go = new GameObject("DieOne");
            var img = go.AddComponent<Image>();
            var view = go.AddComponent<DiceFaceView>();

            var faces = MakeSixFaces();
            SetPrivateField(view, "faceImage", img);
            SetPrivateField(view, "faceSprites", faces);

            //act
            view.SetValue(3);

            //assert
            Assert.AreEqual(faces[2], img.sprite, "Value 3 should map to index 2 (third sprite).");

            //cleanup
            Object.DestroyImmediate(go);
            foreach (var s in faces) { Object.DestroyImmediate(s.texture); Object.DestroyImmediate(s); }
        }

        [Test]
        public void DiceFaceView_Clamps_OutOfRange_ToBounds()
        {
            var go = new GameObject("DieOne");
            var img = go.AddComponent<Image>();
            var view = go.AddComponent<DiceFaceView>();

            var faces = MakeSixFaces();
            SetPrivateField(view, "faceImage", img);
            SetPrivateField(view, "faceSprites", faces);

            //act and assert low
            view.SetValue(0);
            Assert.AreEqual(faces[0], img.sprite, "Values <1 should clamp to 1 (index 0).");

            //act and assert high
            view.SetValue(99);
            Assert.AreEqual(faces[5], img.sprite, "Values >6 should clamp to 6 (index 5).");

            //cleanup
            Object.DestroyImmediate(go);
            foreach (var s in faces) { Object.DestroyImmediate(s.texture); Object.DestroyImmediate(s); }
        }

        [Test]
        public void DiceFaceView_Clear_RemovesSprite()
        {
            var go = new GameObject("DieOne");
            var img = go.AddComponent<Image>();
            var view = go.AddComponent<DiceFaceView>();

            var faces = MakeSixFaces();
            SetPrivateField(view, "faceImage", img);
            SetPrivateField(view, "faceSprites", faces);

            view.SetValue(5);
            Assert.IsNotNull(img.sprite, "Precondition: sprite should be set.");

            //act
            view.Clear();

            //assert
            Assert.IsNull(img.sprite, "Clear() should remove the sprite.");

            //cleanup
            Object.DestroyImmediate(go);
            foreach (var s in faces) { Object.DestroyImmediate(s.texture); Object.DestroyImmediate(s); }
        }
    }
}
