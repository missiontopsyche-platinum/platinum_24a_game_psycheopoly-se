---
config:
    class:
        hideEmptyMembersBox: true
---
classDiagram
    direction LR
    
    note for SpaceData  "add more render
                        details as needed, but
                        for now just color is fine"
    class SpaceData{
        +String spaceName
        +Color spaceColor
        +SpaceHoverEventChannel spaceHoverEventChannel
        +BooleanEventChannel spaceExitEventChannel
        +OnLanded(player: Player)
        +OnPassed(player: Player)
        +OnHover() SpaceHoverEvent
        +OnExit()
    }
    class OwnableSpaceData{
        +int collaborationValue
        -Player owner
        -PurchaseOwnableRequestChannel purchaseOwnableRequestChannel
        -ChargeOwnershipFeeEventChannel chargeOwnershipFeeEventChanel
        +SetOwner(player: Player)
    }
    
    note for PropertyData       "this will be an
                                array with i=0->5,
                                where each index indicates
                                the upgrade level."
    class PropertyData{
        +int[6] researchFundingValues
        +int dataPointCost
        -PurchaseUpgradeRequestEventChannel purchaseUpgradeRequestEventChannel
        -int currentUpgradeLevel
        +UpgradeProperty()
    }
    
    note for PlanetData         "this will be an
                                array i = 0->1,
                                where index indicates # 
                                planets owned by player - 1"
    class PlanetData{
        +int[2] diceMultipliers
        -DiceRolledEventChannel diceRolledEventChannel
        -int lastDiceRoll
        +OnEnable()
        +OnDisable()
        -StoreLastDiceRoll(dre: DiceRolledEvent)
    }
    
    note for InstrumentData     "this will be an
                                array i= 0->3,
                                where index indicates #
                                instruments owned by player"
    class InstrumentData{
        +int[4] researchFundingLevels
    }
    
    class CardSpaceData{
        +CardDeck cardDeck
    }
    
    class ChargeSpaceData{
        -int cost
        -String flavorText
        -ChargePlayerEventChannel chargePlayerEventChannel
    }
    
    class GoSpaceData{
        +int payout
    }

    class LaunchPadSpaceData
    class GravityAssistSpaceData {
        +String flavorText
    }
    class GoForLaunchSpaceData

    SpaceData <|-- TaxSpaceData
    SpaceData <|-- GoSpaceData
    SpaceData <|-- GoForLaunchSpaceData
    SpaceData <|-- GravityAssistSpaceData
    SpaceData <|-- LaunchPadSpaceData
    SpaceData <|-- CardSpaceData
    SpaceData <|-- OwnableSpaceData
    OwnableSpaceData <|-- PlanetData
    OwnableSpaceData <|-- InstrumentData
    OwnableSpaceData <|-- PropertyData