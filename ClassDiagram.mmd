classDiagram
%% Managers
class GameManager {
  <<MonoBehaviour>>
  +GameState gameState
  +static GameManager instance
  +bool TryChangeState(GameState)
  +StartGame(int)
  +EndGame()
  +Initialize()
  +SetUpGame(int)
  +NextTurn()
  +DiceRolled(DiceRolledEvent)
}

class PlayerManager {
  <<MonoBehaviour>>
  -List<Player> players
  +InitializePlayers(int)
  +GetPlayer(int) : Player
  +GetAllPlayers() : List~Player~
  +RemovePlayer(int) : bool
  +PassedGo(int)
  +AddMoney(int,int)
}

class BoardManager {
  <<MonoBehaviour>>
  -int defaultBoardSize
  -Space[] spaces
  -Dictionary<int,int> playerPositions
  +InitializeBoard(int = -1)
  +GetSpace(int) : Space
  +SetPlayerPosition(int,int)
  +GetPlayerPosition(int) : int
  +MovePlayer(MovePlayerEvent)
}

class DiceManager {
  <<MonoBehaviour>>
  -int dieOne
  -int dieTwo
  -int totalRoll
  +RollDice() : DiceRolledEvent
  +RollDiceRequest(bool)
}

%% Rendering and Input Handling
class BoardRenderer {
  <<MonoBehaviour>>
  +Camera mainCamera
  +GameObject spaceRendererPrefab
  +GameObject playerPiecePrefab
  +SpaceRenderer[] spaceRenderers
  +List~Piece~ playerPieces
  +GenerateBoard(Space[])
  +AddPlayerPiece(Player)
  +MovePiece(PlayerMovedEvent)
}

class SpaceRenderer {
  <<InteractableGameObject>>
  +Color color
  +MeshRenderer meshRenderer
  -Space space
  +SetUpSpace(Space,float)
  +OnLeftClick()
  +OnRightClick()
  +OnHoverEnter()
  +OnHoverExit()
  +OnHover()
}

class Piece {
  <<MonoBehaviour>>
  -Color pieceColor
  -float moveSpeed
  +MeshRenderer meshRenderer
  +int playerId
  +int spaceIndex
  +InitializePiece(int,string,Color)
  +MoveTo(Vector3)
}

class InputManager {
  <<MonoBehaviour>>
  -Camera mainCamera
  -IHoverable currentHovered
}

%% UI
class UIPanelBase {
  <<MonoBehaviour>>
  -List~Action~ unsubscribers
  #Subscribe<T>(EventChannel<T>, Action<T>)
  #ClearSubscriptions()
  #SetTextSafe(Text,string)
}

class DicePanelController {
  <<UIPanelBase>>
  +Text dice1RolledText
  +Text dice2RolledText
  +Text diceTotalText
  +Button rollDiceButton
  +DisplayDiceRoll(DiceRolledEvent)
  +RollDiceClicked()
}

class PlayerPanelController {
  <<UIPanelBase>>
  -List~Player~ playersList
  +Text playerNameText
  +Text playerMoneyText
  +DisplayCurrentPlayer(TurnStartedEvent)
  +AddPlayer(Player)
}

class TurnPanelController {
  <<UIPanelBase>>
  +Text turnNumberText
  +DisplayCurrentTurn(TurnStartedEvent)
}

class DiceRollPanelController {
  <<MonoBehaviour>>
  -DiceManager diceManager
  -DiceFaceView dieOneView
  -DiceFaceView dieTwoView
  -Text totalText
  -Button rollButton
  -bool hideUntilFirstRoll
  -OnRollClicked()
  -OnDiceRolled(DiceRolledEvent)
}

class DiceFaceView {
  <<MonoBehaviour>>
  -Image faceImage
  -Sprite[] faceSprites
  +SetValue(int)
  +Clear()
}

%% Models
class Player {
  <<ScriptableObject>>
  -int id
  -string p_Name
  -int money
  -int position
  -bool inJail
  -int jailTurns
  -int doublesInRow
  -List~int~ ownedProperties
  -Color32 color
  +SetId(int) / GetId() : int
  +SetPName(string) / GetPName() : string
  +SetMoney(int) / GetMoney() : int
  +SetPosition(int) / GetPosition() : int
  +SetColor(Color32) / GetColor() : Color32
  +GetInJail() : bool
  +GetJailTurns() : int
  +GetDoublesInRow() : int
  +GetOwnedProperties() : List~int~
  +GoToJail() ...
}

class Space {
  <<abstract>>
  -string Name
  +OnLanded(Player)
}
class GoSpace
class ChanceSpace
class PropertySpace

Space <|-- GoSpace
Space <|-- ChanceSpace
Space <|-- PropertySpace

%% Events and Channels
class GameState {
  <<enum>>
  None
  Initializing
  WaitingForTurn
  PlayerTurn
  BotTurn
  GameOver
}

class DiceRolledEvent {
  +int dieOne
  +int dieTwo
  +int totalRoll
}

class MovePlayerEvent {
  +int id
  +int spacesToMove
}

class PlayerMovedEvent {
  +int id
  +int previousPosition
  +int newPosition
}

class TurnStartedEvent {
  +int playerId
  +int turnNum
}

class GameStateChangedEvent {
  +GameState oldState
  +GameState newState
}

class EventChannel~T~ {
  <<ScriptableObject>>
  +Subscribe(Action~T~)
  +Unsubscribe(Action~T~)
  +RaiseEvent(T)
  +ClearAllListeners()
}

class DiceRolledEventChannel
class RollDiceRequestedEventChannel
class PlayerEventChannel
class PlayerMovedEventChannel
class MovePlayerEventChannel
class TurnStartedEventChannel
class GameStateChangedEventChannel
class IntEventChannel

EventChannel~DiceRolledEvent~ <|-- DiceRolledEventChannel
EventChannel~bool~ <|-- RollDiceRequestedEventChannel
EventChannel~Player~ <|-- PlayerEventChannel
EventChannel~PlayerMovedEvent~ <|-- PlayerMovedEventChannel
EventChannel~MovePlayerEvent~ <|-- MovePlayerEventChannel
EventChannel~TurnStartedEvent~ <|-- TurnStartedEventChannel
EventChannel~GameStateChangedEvent~ <|-- GameStateChangedEventChannel
EventChannel~int~ <|-- IntEventChannel

%% Interfaces
class IHoverable {
  <<interface>>
  +OnHoverEnter()
  +OnHover()
  +OnHoverExit()
}
class IClickable {
  <<interface>>
  +OnLeftClick()
  +OnRightClick()
}
class InteractableGameObject {
  <<MonoBehaviour>>
}
InteractableGameObject ..|> IHoverable
InteractableGameObject ..|> IClickable
SpaceRenderer --|> InteractableGameObject

%% Associations
GameManager ..> PlayerManager : via events (init players)
GameManager --> GameStateChangedEventChannel
GameManager --> TurnStartedEventChannel
GameManager --> PlayerMovedEventChannel
GameManager --> IntEventChannel : initializePlayerCount
GameManager --> DiceRolledEventChannel
GameManager --> MovePlayerEventChannel

PlayerManager --> PlayerEventChannel : add/remove
PlayerManager --> IntEventChannel : subscribe (initialize count)
PlayerManager --> IntEventChannel : subscribe (passed go)
PlayerManager o-- "many" Player

BoardManager --> BoardRenderer
BoardManager --> PlayerMovedEventChannel : raise
BoardManager --> MovePlayerEventChannel : subscribe
BoardManager --> IntEventChannel : raise (passedGo)
BoardManager --> EventChannel~DiceRolledEvent~ : (ref)
BoardManager o-- "many" Space

BoardRenderer --> PlayerEventChannel : subscribe (added)
BoardRenderer --> PlayerMovedEventChannel : subscribe (move)
BoardRenderer o-- "many" SpaceRenderer
BoardRenderer o-- "many" Piece

SpaceRenderer --> Space : renders

DiceManager --> DiceRolledEventChannel : raise
DiceManager --> RollDiceRequestedEventChannel : subscribe

DicePanelController --|> UIPanelBase
DicePanelController --> DiceRolledEventChannel : subscribe
DicePanelController --> RollDiceRequestedEventChannel : raise

PlayerPanelController --|> UIPanelBase
PlayerPanelController --> TurnStartedEventChannel : subscribe
PlayerPanelController --> PlayerEventChannel : subscribe

TurnPanelController --|> UIPanelBase
TurnPanelController --> TurnStartedEventChannel : subscribe

InputManager ..> IHoverable
InputManager ..> IClickable
